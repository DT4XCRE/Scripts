local function updateVisuals()
    toggleBtn.Text = farming_enabled and "MOB FARM: ON [K]" or "MOB FARM: OFF [K]"
    toggleBtn.BackgroundColor3 = farming_enabled and NEON_CYAN or Color3.fromRGB(30,30,35)
    modeBtn.Text = "MODE: " .. farm_mode:upper()
    clickBtn.Text = autoclick_enabled and "AUTOCLICK: ON [L]" or "AUTOCLICK: OFF [L]"
    stablize(farming_enabled)
end

local function updateList()
    for _, item in ipairs(scroll:GetChildren()) do
        if item:IsA("TextButton") then item:Destroy() end
    end
    local counts = {}
    for _, v in ipairs(MOB_FOLDER:GetChildren()) do
        if v:IsA("Model") and not isPet(v) then
            local n = cleanName(v.Name)
            counts[n] = (counts[n] or 0) + 1
        end
    end
    local sorted = {}
    for n in pairs(counts) do table.insert(sorted, n) end
    table.sort(sorted)

    local function createButton(name, display)
        local b = Instance.new("TextButton", scroll)
        b.Size = UDim2.new(0.95, 0, 0, 30)
        b.Text = display
        b.BackgroundColor3 = (selected_npc_name == name) and NEON_CYAN or Color3.fromRGB(40,40,45)
        b.TextColor3 = (selected_npc_name == name) and Color3.new(0,0,0) or Color3.new(1,1,1)
        b.Font = Enum.Font.Gotham
        b.TextSize = 11
        Instance.new("UICorner", b)
        b.MouseButton1Click:Connect(function()
            selected_npc_name = name
            updateList()
            saveLocal()
        end)
    end

    createButton("All", "All (Filtered)")
    for _, n in ipairs(sorted) do
        createButton(n, n .. " ("..counts[n]..")")
    end
    scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 10)
end

local function saveOnChange()
    settings.farming_enabled = farming_enabled
    settings.autoclick_enabled = autoclick_enabled
    settings.farm_mode = farm_mode
    settings.farm_distance = farm_distance
    settings.selected_npc_name = selected_npc_name
    settings.auto_skills = {
        E = auto_skills[Enum.KeyCode.E],
        R = auto_skills[Enum.KeyCode.R],
        F = auto_skills[Enum.KeyCode.F],
        X = auto_skills[Enum.KeyCode.X]
    }
    saveLocal()
end

