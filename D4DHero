-- =============== SAVING ===============
local localFile = "D4DHero_Settings.json"

local settings = {
    farming_enabled = false,
    autoclick_enabled = false,
    farm_mode = "Top",
    farm_distance = 10,
    selected_npc_name = "All",
    auto_skills = {E = false, R = false, F = false, X = false}
}

local function saveLocal()
    pcall(function() writefile(localFile, HttpService:JSONEncode(settings)) end)
end

local function loadLocal()
    if isfile(localFile) then
        pcall(function()
            local data = HttpService:JSONDecode(readfile(localFile))
            for k,v in pairs(data) do
                if k == "auto_skills" then
                    for skill,val in pairs(v) do settings.auto_skills[skill] = val end
                else
                    settings[k] = v
                end
            end
        end)
    end
end

