-- =============== FUNCTIONS ===============
local function getValidHRP()
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then return char.HumanoidRootPart end
    return nil
end

local function stablize(state)
    local hrp = getValidHRP()
    if not hrp then return end
    if state then
        local bv = hrp:FindFirstChild("D4DHero_BV") or Instance.new("BodyVelocity")
        bv.Name = "D4DHero_BV"; bv.Velocity = Vector3.zero; bv.MaxForce = Vector3.new(9e9,9e9,9e9); bv.Parent = hrp
        local bg = hrp:FindFirstChild("D4DHero_BG") or Instance.new("BodyGyro")
        bg.Name = "D4DHero_BG"; bg.MaxTorque = Vector3.new(9e9,9e9,9e9); bg.P = 50000; bg.Parent = hrp
        if farm_mode == "Top" then bg.CFrame = CFrame.Angles(math.rad(-90), 0, 0) end
    else
        for _,v in {"D4DHero_BV","D4DHero_BG"} do if hrp:FindFirstChild(v) then hrp[v]:Destroy() end end
    end
end

local function isPet(model) return model:FindFirstChild("PetItemRef") ~= nil end
local function cleanName(name) return tostring(name):gsub("%s+", "") end

local function getBestTarget(myHrp)
    local now = tick()
    if current_target_model then
        local hum = current_target_model:FindFirstChildOfClass("Humanoid")
        if not current_target_model.Parent or (hum and hum.Health <= 0) then
            blacklist[current_target_model] = now
            current_target_model = nil
        end
    end
    for m,t in pairs(blacklist) do if now - t > 3 then blacklist[m] = nil end end

    if current_target_model and current_target_model.Parent then
        local rp = current_target_model:FindFirstChild("HumanoidRootPart") or current_target_model.PrimaryPart
        if rp then return {model = current_target_model, root = rp} end
    end

    local mobs = MOB_FOLDER:GetChildren()
    local targetClean = cleanName(selected_npc_name)
    local nearest, dist = nil, math.huge

    for _, v in ipairs(mobs) do
        if v:IsA("Model") and not blacklist[v] and not isPet(v) then
            local cName = cleanName(v.Name)
            if targetClean == "All" or cName == targetClean then
                local rp = v:FindFirstChild("HumanoidRootPart") or v.PrimaryPart
                if rp then
                    local h = v:FindFirstChildOfClass("Humanoid")
                    if not h or h.Health > 0 then
                        local d = (myHrp.Position - rp.Position).Magnitude
                        if d < dist then dist = d; nearest = {model = v, root = rp} end
                    end
                end
            end
        end
    end
    if nearest then current_target_model = nearest.model end
    return nearest
end

