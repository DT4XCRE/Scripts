-- =============== LOOPS ===============
task.spawn(function()
    while is_script_active do
        if farming_enabled then
            local hrp = getValidHRP()
            if hrp then
                local target = getBestTarget(hrp)
                if target and target.root then
                    local offsetCFrame
                    if farm_mode == "Top" then
                        offsetCFrame = target.root.CFrame * CFrame.new(0, farm_distance, 0) * CFrame.Angles(math.rad(-90), 0, 0)
                    else
                        local behindPos = target.root.Position + (target.root.CFrame.LookVector * -5) + Vector3.new(0, farm_distance/2, 0)
                        offsetCFrame = CFrame.new(behindPos, target.root.Position)
                    end
                    local tdist = (hrp.Position - offsetCFrame.Position).Magnitude
                    if currentTween then currentTween:Cancel() end
                    currentTween = TweenService:Create(hrp, TweenInfo.new(tdist/FLY_SPEED, Enum.EasingStyle.Linear), {CFrame = offsetCFrame})
                    currentTween:Play()
                end
            end
        end
        task.wait(0.1)
    end
end)

-- Autoclick + Auto Skills loops (same as before)
task.spawn(function()
    while is_script_active do
        if autoclick_enabled then
            VirtualInputManager:SendMouseButtonEvent(500, 500, 0, true, game, 0)
            task.wait(0.01)
            VirtualInputManager:SendMouseButtonEvent(500, 500, 0, false, game, 0)
        end
        task.wait(0.05)
    end
end)

task.spawn(function()
    while is_script_active do
        for key, active in pairs(auto_skills) do
            if active then
                VirtualInputManager:SendKeyEvent(true, key, false, game)
                task.wait(0.05)
                VirtualInputManager:SendKeyEvent(false, key, false, game)
            end
        end
        task.wait(0.1)
    end
end)

UserInputService.InputBegan:Connect(function(input, processed)
    if processed or not is_script_active then return end
    if input.KeyCode == Enum.KeyCode.K then
        farming_enabled = not farming_enabled
        updateVisuals()
        saveOnChange()
    elseif input.KeyCode == Enum.KeyCode.L then
        autoclick_enabled = not autoclick_enabled
        updateVisuals()
        saveOnChange()
    end
end)

