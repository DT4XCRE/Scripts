    text.Text = name
    text.TextColor3 = color
    text.TextStrokeTransparency = 0
    text.Font = Enum.Font.GothamBold
    text.TextSize = 14
    text.Parent = billboard
end

local function updateAllESP()
    -- Ores (Black)
    if oreEspEnabled then
        local deposits = Workspace:FindFirstChild("Deposits")
        if deposits then
            for _, dep in ipairs(deposits:GetChildren()) do
                for _, ore in ipairs(dep:GetChildren()) do
                    if ore:IsA("BasePart") then
                        local name = ore.Name
                        if not (name:find("Model") or name:find("Union") or name:find("Spawn") or name:find("Hitbox")) then
                            local displayName = name:gsub("OreHitbox", ""):gsub("Resource", ""):gsub("Hitbox", "")
                            createESP(ore, displayName, Color3.fromRGB(40, 40, 40))
                        end
                    end
                end
            end
        end
    end

    -- Harvestables (Blue) - Only show "Harvestable" if has Drop
    if harvestEspEnabled then
        local harvestables = Workspace:FindFirstChild("Harvestables")
        if harvestables then
            for _, obj in ipairs(harvestables:GetDescendants()) do
                if obj:IsA("BasePart") and obj:FindFirstChild("Drop") or (obj.Parent and obj.Parent:FindFirstChild("Drop")) then
                    createESP(obj, "Harvestable", Color3.fromRGB(80, 180, 255))
                end
            end
        end
    end

    -- Mobs (Red)
    if mobEspEnabled then
        for _, mob in ipairs(Workspace.Mobs:GetChildren()) do
            if table.find(targetMobs, mob.Name) then
                createESP(mob, mob.Name, Color3.fromRGB(255, 80, 80))
            end
        end
    end
end

-- =============== VALIDATION ===============
local function isValidOre(ore)
    if not ore or not ore:IsA("BasePart") then return false end
    local nameStr = (ore.Name or ""):lower() .. " " .. (ore.Parent and ore.Parent.Name or ""):lower()

    if selectedOreType == "All" then return true end
    if selectedOreType == "Quartz" and nameStr:find("quartz") then return true end
    if selectedOreType == "Coal" and nameStr:find("coal") then return true end
    if selectedOreType == "Stone" and (nameStr:find("stone") or nameStr:find("stoneresource")) then return true end
    if selectedOreType == "Cya" and nameStr:find("cyastone") then return true end
    if selectedOreType == "Iron" and nameStr:find("iron") then return true end
    if selectedOreType == "Copper" and nameStr:find("copper") then return true end

    return false
end

local function isValidHarvestable(obj)
    if not obj or not obj:IsA("BasePart") or (obj.Transparency and obj.Transparency > 0.7) then return false end
    local hasDrop = obj:FindFirstChild("Drop") or (obj.Parent and obj.Parent:FindFirstChild("Drop"))
    if not hasDrop then return false end

    local name = (obj.Name or ""):lower()
    local parentName = (obj.Parent and obj.Parent.Name or ""):lower()
    local fullName = name .. " " .. parentName

    if selectedHarvestType == "All" then return true end
    local target = selectedHarvestType:lower()

    if fullName:find(target) then return true end
    if target == "claretflower" and fullName:find("claret") then return true end
    if target == "rootherb" and fullName:find("rootherb") then return true end
    if target == "glarecap" and fullName:find("glare") then return true end
    if target == "babmushroom" and (fullName:find("bab") or fullName:find("mushroom")) then return true end

    return false
end

