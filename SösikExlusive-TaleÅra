-- =============== FARM LOGIC ===============
local function findBestOre()
    local best, bestDist = nil, math.huge
    local deposits = Workspace:FindFirstChild("Deposits")
    if not deposits then return nil end

    for _, obj in ipairs(deposits:GetDescendants()) do
        if isValidOre(obj) then
            local dist = (hrp.Position - obj.Position).Magnitude
            if dist < bestDist then
                bestDist = dist
                best = obj
            end
        end
    end
    return best
end

task.spawn(function()
    while true do
        if oreFarmEnabled and hrp then
            local target = findBestOre()
            if target then
                currentTarget = target
                lastHitTime = tick()

                local dir = (target.Position - hrp.Position).Unit
                local targetPos = target.Position - dir * farmDistance
                hrp.CFrame = CFrame.new(targetPos, target.Position)
            end

            if autoClickEnabled and currentTarget and (tick() - lastHitTime < settings.timeout) then
                if tick() - lastClickTime > 0.07 then
                    VirtualInputManager:SendMouseButtonEvent(600, 400, 0, true, game, 0)
                    task.wait(0.03)
                    VirtualInputManager:SendMouseButtonEvent(600, 400, 0, false, game, 0)
                    lastClickTime = tick()
                end
            end
        end
        task.wait(0.15)
    end
end)

