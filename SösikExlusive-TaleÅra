-- =============== SETTINGS ===============
local localFile = "D4DHero_OreFarm_Settings.json"
local settings = {
    ore_farm_enabled = false,
    autoclick_enabled = false,
    farm_distance = 5,
    move_speed = 50,
    selected_ore_type = "All",
    timeout = 15
}

local function saveSettings()
    pcall(function() writefile(localFile, HttpService:JSONEncode(settings)) end)
end

local function loadSettings()
    if isfile(localFile) then
        pcall(function()
            local data = HttpService:JSONDecode(readfile(localFile))
            for k,v in pairs(data) do settings[k] = v end
        end)
    end
end
