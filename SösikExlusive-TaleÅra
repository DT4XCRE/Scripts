-- Ore Types
local oreOptions = {"All", "Quartz", "Coal", "Stone", "Cya", "Iron", "Copper"}

local function isValidOre(part)
    if not part or not part:IsA("BasePart") then return false end
    if part.Transparency > 0.8 then return false end

    local fullName = (part.Name or "") .. " " .. (part.Parent and part.Parent.Name or "")
    
    if selectedOreType == "All" then return true end
    
    if selectedOreType == "Cya" and fullName:find("Cyastone") then return true end
    if selectedOreType == "Quartz" and fullName:find("Quartz") then return true end
    if selectedOreType == "Coal" and fullName:find("Coal") then return true end
    if selectedOreType == "Stone" and (fullName:find("Stone") or fullName:find("StoneResource")) then return true end
    if selectedOreType == "Iron" and fullName:find("Iron") then return true end
    if selectedOreType == "Copper" and fullName:find("Copper") then return true end
    return false
end

