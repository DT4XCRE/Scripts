local function createESP(part, name, color)
    if part:FindFirstChild("SösikESP") then return end

    local highlight = Instance.new("Highlight")
    highlight.Name = "SösikESP"
    highlight.FillColor = color
    highlight.OutlineColor = color
    highlight.FillTransparency = 0.4
    highlight.OutlineTransparency = 0
    highlight.Parent = part

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "SösikNameTag"
    billboard.Adornee = part
    billboard.Size = UDim2.new(0, 200, 0, 50)
    billboard.StudsOffset = Vector3.new(0, 4, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = part

    local text = Instance.new("TextLabel")
    text.Size = UDim2.new(1,0,1,0)
    text.BackgroundTransparency = 1
    text.Text = name
    text.TextColor3 = color
    text.TextStrokeTransparency = 0
    text.TextStrokeColor3 = Color3.fromRGB(0,0,0)
    text.Font = Enum.Font.GothamBold
    text.TextSize = 16
    text.Parent = billboard
end

local function updateMobESP()
    local mobsFolder = Workspace:FindFirstChild("Mobs")
    if not mobsFolder then return end
    for _, mob in ipairs(mobsFolder:GetChildren()) do
        if table.find(targetMobs, mob.Name) then
            createESP(mob, mob.Name, Color3.fromRGB(255, 80, 80))
        end
    end
end

-- =============== VALIDATION ===============
local function isValidOre(ore)
    if not ore or not ore:IsA("BasePart") then return false end

    local name = (ore.Name or ""):lower()
    local parentName = (ore.Parent and ore.Parent.Name or ""):lower()
    local fullStr = name .. " " .. parentName

    if selectedOreType == "All" then return true end

    if selectedOreType == "Quartz" and fullStr:find("quartz") then return true end
    if selectedOreType == "Coal" and fullStr:find("coal") then return true end
    if selectedOreType == "Stone" and (fullStr:find("stone") or fullStr:find("rock")) then return true end
    if selectedOreType == "Cya" and fullStr:find("cya") then return true end
    if selectedOreType == "Iron" and fullStr:find("iron") then return true end
    if selectedOreType == "Copper" and fullStr:find("copper") then return true end

    return false
end

local function isValidHarvestable(obj)
    if not obj or not obj:IsA("BasePart") or (obj.Transparency and obj.Transparency > 0.7) then return false end
    if not (obj:FindFirstChild("Drop") or (obj.Parent and obj.Parent:FindFirstChild("Drop"))) then return false end

    local fullName = (obj.Name or ""):lower() .. " " .. (obj.Parent and obj.Parent.Name or ""):lower()
    if selectedHarvestType == "All" then return true end
    local t = selectedHarvestType:lower()
    if fullName:find(t) then return true end
    if t == "wind rootherb" and fullName:find("wind") then return true end
    return false
end

local function toggleBrightness(state)
    if state then
        Lighting.Brightness = 2
        Lighting.ClockTime = 14
        Lighting.Ambient = Color3.fromRGB(255,255,255)
        Lighting.FogEnd = 100000
    else
        Lighting.Brightness = 1
        Lighting.ClockTime = 12
        Lighting.Ambient = Color3.fromRGB(100,100,100)
        Lighting.FogEnd = 10000
    end
end

