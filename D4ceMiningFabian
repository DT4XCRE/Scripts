end)

jellyToggle.MouseButton1Click:Connect(function()
    jellyEnabled = not jellyEnabled
    if jellyEnabled then
        jellyToggle.BackgroundColor3 = Color3.fromRGB(0, 200, 80)
        jellyToggle.Text = "GULP"
        jellyConn = RunService.Heartbeat:Connect(teleportToJellyfish)
    else
        jellyToggle.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
        jellyToggle.Text = "Gulp"
        if jellyConn then jellyConn:Disconnect() jellyConn = nil end
    end
end)

ufoToggle.MouseButton1Click:Connect(function()
