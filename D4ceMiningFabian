local function teleportToSell()
    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local p = workspace:FindFirstChild("FarmStar", true)
    if p then p = p:FindFirstChild("Platforms", true) end
    if p then p = p:FindFirstChild("302132620") end
    if p then p = p:FindFirstChild("Shops", true) end
    if p then p = p:FindFirstChild("Shop", true) end
    if p then 
        local target = p:FindFirstChild("SellShop") or p:FindFirstChild("FS_SellPromptAnchor")
        if target then
            local part = target:FindFirstChildWhichIsA("BasePart") or target
            root.CFrame = part.CFrame * CFrame.new(8, 6, 0)
        end
    end
end

local function collectAllDocks()
    for i = 1, 40 do
        pcall(function()
            collectRemote:FireServer({ dockIndex = i })
        end)
        task.wait(0.08)
    end
end

local function teleportToJellyfish()
    local folder = workspace:FindFirstChild("FarmStar", true)
    if folder then folder = folder:FindFirstChild("ActiveEvent", true) end
    if folder then folder = folder:FindFirstChild("Incidents", true) end
    if folder then folder = folder:FindFirstChild("JellyFish") end
    if not folder then return end

    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    for _, obj in ipairs(folder:GetChildren()) do
        local part = obj:FindFirstChild("Center") or obj:FindFirstChildWhichIsA("BasePart") or obj
        if part then
            root.CFrame = part.CFrame + Vector3.new(0, 8, 0)
            task.wait(0.5)
        end
    end
end

local function teleportToUFO()
    local folder = workspace:FindFirstChild("FarmStar", true)
    if folder then folder = folder:FindFirstChild("ActiveEvent", true) end
    if folder then folder = folder:FindFirstChild("Incidents", true) end
    if folder then folder = folder:FindFirstChild("UFO") end
    if not folder then return end

    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    for _, obj in ipairs(folder:GetChildren()) do
        local part = obj:FindFirstChildWhichIsA("BasePart") or obj
        if part then
            root.CFrame = part.CFrame + Vector3.new(0, 10, 0)
            task.wait(0.6)
        end
    end
end

